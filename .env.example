# TV Display Environment Variables
# These are baked into the build at compile time (Vite)
# When using Nginx reverse proxy (default), leave these empty/relative
VITE_API_URL=http://localhost:8082/api
VITE_WS_URL=http://localhost:8082/ws-game
# For local development without Nginx proxy:
# VITE_API_URL=http://localhost:8080/api
# VITE_WS_URL=http://localhost:8080/ws-game
